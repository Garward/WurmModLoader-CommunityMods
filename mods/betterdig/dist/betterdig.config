# Override template weight for these dig resources (grams per item). -1 = vanilla.
#overrideClayWeight=-1
#overrideTarWeight=-1
#overridePeatWeight=-1
#overrideMossWeight=-1

# Routing when digging on / with a vehicle attached
#digToVehicle=false
#dredgeToShip=false
#digToCrates=false
#digToDragged=false
#levelToVehicle=false
#levelToDragged=false

# Routing for flatten/level dirt lookups (where the performer pulls dirt from)
#levelFromVehicle=false
#levelFromDragged=false
#levelFromCrates=false
#levelFromGround=false

# Comma-separated action names (from com.wurmonline.server.behaviours.Actions)
# that should be permitted while mounted. e.g. DIG,PACK,CULTIVATE
#allowWhenMounted=
